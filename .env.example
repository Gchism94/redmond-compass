# Which data source the app reads from (BUILD-BRIEF §2). The frontend is identical
# either way — only this flag + a DataSource implementation change.
#   mock     — in-memory fictional seed data (default for dev, no backend needed)
#   supabase — read from Supabase (recommended path B in DATA-SOURCE.md)
#   base44   — consume base44's API directly (not implemented)
VITE_DATA_SOURCE=mock

# Required when VITE_DATA_SOURCE=supabase. Get local values from `supabase status`
# (or your hosted project settings). The anon/publishable key is safe in the client;
# RLS protects the data. NEVER ship the service_role/secret key to the browser.
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
