# Which data source the app reads from (BUILD-BRIEF §2). The frontend is identical
# either way — only this flag + a DataSource implementation change.
#   mock     — in-memory fictional seed data (default, MVP dev)
#   base44   — consume base44's API directly  (TODO: pending §14 decision)
#   supabase — shared Postgres backend        (TODO: pending §14 decision)
VITE_DATA_SOURCE=mock
